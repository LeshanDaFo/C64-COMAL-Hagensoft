{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build -> C64 -> Hagensoft",
            "type": "shell",
            "osx": {
                "command": "sh scripts/build.sh"
            },
            "linux": {
                "command": "sh scripts/build.sh"
            },
            "windows": {
                "command": "scripts\\build.bat"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "clear": true
            },
            "problemMatcher": {
                "owner": "acme",
                "fileLocation": ["relative", "${workspaceFolder}"],
                "pattern": {
                    "regexp": "^(Error - File\\s+(.*), line (\\d+) (\\(Zone .*\\))?:\\s+(.*))$",
                    "file": 2,
                    "location": 3,
                    "message": 1
                }
            }
        }
    ]
}
